<body class="<?php echo (isset($_GET['monitor']) && $_GET['monitor'] === '1') ? 'monitor-entry' : ''; ?>">
<button id="mobile-toggle" class="btn" type="button">Clientes</button>
<div id="app">
  <aside id="sidebar">
    <div class="header"><div class="header-title"><h1>MAPA DE CLIENTES</h1><a class="back-mkauth" href="/admin/">VOLTAR NO MK-AUTH</a></div><div class="counters">
      <button class="counter active" data-filter="all"><strong id="count-total">—</strong><span>Total</span></button>
      <button class="counter" data-filter="online"><strong id="count-online">—</strong><span>Online</span></button>
      <button class="counter" data-filter="offline"><strong id="count-offline">—</strong><span>Offline</span></button>
      <button class="counter" data-filter="unmapped"><strong id="count-unmapped">—</strong><span>Sem coordenadas</span></button>
    </div></div>
    <div class="tools"><input id="search" type="search" placeholder="Buscar nome, login, IP ou MAC">
      <div class="row"><button id="refresh" class="btn" type="button">Atualizar</button><button id="fit" class="btn" type="button">Ver clientes no mapa</button><label class="refresh-label">Tema <select id="theme-select"><option value="dark" selected>Dark</option><option value="white">White</option></select></label></div>
      <div class="row compact-config"><label class="refresh-label">Atualizar <select id="refresh-interval"><option value="30">30 seg</option><option value="60" selected>60 seg</option><option value="300">5 min</option></select></label><label class="refresh-label">Alerta <select id="mass-threshold"><option value="0">Nenhum</option><option value="5">5 Clientes</option><option value="10" selected>10 Clientes</option><option value="20">20 Clientes</option><option value="50">50 Clientes</option><option value="100">100 Clientes</option><option value="200">200 Clientes</option><option value="500">500 Clientes</option></select></label></div>
      <div class="row"><label class="toggle"><input id="clusters" type="checkbox" checked> Agrupar marcadores</label><label class="toggle"><input id="notifications" type="checkbox" checked> Notificações</label><label class="toggle"><input id="alert-sound" type="checkbox" checked> Sirene</label></div><label id="persistent-access-button" class="persistent-access <?php echo $map_persistent_access ? 'active' : ''; ?>"><input id="persistent-access" type="checkbox" <?php echo $map_persistent_access ? 'checked' : ''; ?>><span><?php echo $map_persistent_access ? 'DESTRAVAR MAPA' : 'FIXAR MAPA'; ?></span></label>
      <div class="row"><span id="updated" class="updated"></span><span id="countdown" class="updated">Próxima atualização: —</span></div>
    </div>
    <div id="client-list"><div class="empty">Carregando clientes…</div></div>
  </aside>
  <button id="sidebar-toggle" class="sidebar-toggle" type="button" title="Esconder painel de clientes"><span>‹</span></button>
  <main id="map"></main>
</div>
<div id="toast-container"></div>
<div id="critical-alert" role="alertdialog" aria-modal="true" aria-labelledby="critical-title"><div class="critical-card"><h2 id="critical-title">ALERTA CRÍTICO</h2><div class="critical-count"><span id="critical-count">0</span></div><p>PPPoE ficaram offline em massa</p><button id="critical-close" type="button">Silenciar e fechar</button></div></div>
<div id="coordinate-modal" role="dialog" aria-modal="true" aria-labelledby="coordinate-title"><div class="coordinate-card"><div class="coordinate-head"><h2 id="coordinate-title">Pesquisar e adicionar coordenadas</h2><p id="coordinate-client"></p></div><div class="registered-address"><strong>Endereço cadastrado, mas coordenada não preenchida</strong><span id="registered-address-text">Endereço não informado no cadastro.</span><div class="registered-address-actions"><a id="coordinate-client-edit" class="btn" target="_blank" rel="noopener">Alterar diretamente no cadastro</a><a id="coordinate-google-maps" class="btn" target="_blank" rel="noopener">Abrir Google Maps</a></div></div><div class="coordinate-search"><input id="coordinate-search" type="search" placeholder="Digite endereço, número, bairro, cidade, UF ou CEP"><button id="coordinate-search-button" class="btn active" type="button">Pesquisar</button></div><div class="coordinate-tip"><strong>Ajuste fino:</strong> escolha um resultado e depois clique no mapa ou arraste o marcador até o ponto exato.</div><div class="coordinate-body"><div id="coordinate-suggestions" class="coordinate-suggestions"><div class="empty">Digite pelo menos 3 caracteres para pesquisar.</div></div><div id="coordinate-map"></div></div><div class="coordinate-footer"><div class="coord-grid"><label>Latitude<input id="coordinate-lat" inputmode="decimal" placeholder="Ex.: -5.0892100"></label><label>Longitude<input id="coordinate-lon" inputmode="decimal" placeholder="Ex.: -42.8016200"></label></div><label class="coord-options"><input id="coordinate-fill-address" type="checkbox"> Preencher o endereço de instalação usando o resultado localizado</label><div id="coordinate-error" class="coord-error"></div><div class="coord-actions"><button id="coordinate-center" class="btn" type="button">Usar centro atual do mapa</button><button id="coordinate-cancel" class="btn" type="button">Cancelar</button><button id="coordinate-save" class="btn active" type="button">Confirmar e salvar</button></div></div></div></div>
<div id="demo-bar" class="demo-bar collapsed"><button id="guide-open" class="help-button" type="button" title="Guia de uso" aria-label="Abrir guia de uso">?</button><button id="demo-toggle" class="demo-toggle" type="button" title="Abrir alertas"><span>‹</span></button><div class="demo-content"><strong>Alertas:</strong><select id="demo-alert"><option value="siren">Sirene</option><option value="mass">Alerta em massa</option><option value="online">Popup cliente online</option><option value="offline">Popup cliente offline</option><option value="both">Sirene e alerta em massa</option></select><button id="demo-run" type="button">Executar</button></div></div>
<div id="guide-modal" class="guide-modal" role="dialog" aria-modal="true" aria-labelledby="guide-title"><div class="guide-card"><div class="guide-head"><h2 id="guide-title">Guia completo do Mapa de Clientes</h2><button id="guide-close" class="guide-close" type="button">Fechar</button></div><div class="guide-stage">
<section class="guide-slide active"><h3>1. Visão geral e filtros</h3><p>Os cartões do topo também funcionam como filtros. Clique em Total, Online, Offline ou Sem coordenadas. A busca encontra clientes por nome, login, IP ou MAC.</p><ul class="guide-steps"><li>Verde: clientes online.</li><li>Vermelho: clientes offline.</li><li>Laranja: cadastro sem latitude e longitude.</li><li>Clique novamente em Total para retornar à lista completa.</li></ul><div class="guide-visual"><span class="guide-chip">Total</span><span class="guide-chip green">Online</span><span class="guide-chip red">Offline</span><span class="guide-chip orange">Sem coordenadas</span></div></section>
<section class="guide-slide"><h3>2. Atualização e visualização</h3><p>Escolha a frequência em Atualizar: 30 seg, 60 seg ou 5 min. O contador informa quanto falta para a próxima coleta. Atualizar força uma coleta imediata.</p><ul class="guide-steps"><li>Ver clientes no mapa ajusta o enquadramento dos pontos visíveis.</li><li>Tema alterna entre Dark e White.</li><li>MAPA alterna entre mapa de ruas e satélite.</li><li>Agrupar marcadores melhora a visualização quando existem muitos clientes próximos.</li></ul><div class="guide-visual"><span class="guide-chip">60 seg</span><span class="guide-chip">Mapa</span><span class="guide-chip">Satélite</span><span class="guide-chip green">Agrupar</span></div></section>
<section class="guide-slide"><h3>3. Localizar e consultar um cliente</h3><p>Clique no cliente da lista. Se houver coordenada, o mapa aproxima o ponto, executa o radar e abre as informações disponíveis no cadastro e na sessão.</p><ul class="guide-steps"><li>São mostrados status, contrato, tempo online, conexão, desconexão, IP, MAC, NAS, porta NAS e plano.</li><li>Use LOG ao lado da última desconexão para abrir o histórico de conexões.</li><li>CTO e Porta CTO aparecem somente quando estiverem preenchidas no cadastro.</li><li>O cadeado identifica contrato bloqueado.</li><li>Se o ponto estiver incorreto ou fora da região, use AJUSTAR LOCALIZAÇÃO no popup, reposicione o marcador e confirme.</li><li>O radar pode ser repetido clicando novamente no cliente.</li></ul><div class="guide-visual"><div class="guide-map"><span class="guide-pin"></span></div><span class="guide-chip blue">AJUSTAR LOCALIZAÇÃO</span><span class="guide-chip">LOG</span></div></section>
<section class="guide-slide"><h3>4. Cadastrar coordenadas pelo endereço</h3><p>Clique em um cliente com a etiqueta laranja Sem coordenadas. A janela apresenta o endereço já cadastrado e permite localizar a instalação.</p><ol class="guide-steps"><li>Confira o endereço exibido ou use Alterar diretamente no cadastro.</li><li>Edite a pesquisa se necessário e clique em Pesquisar.</li><li>Selecione um resultado e ajuste o marcador clicando ou arrastando no mini mapa.</li><li>Use Mapa ou Satélite para conferir o imóvel.</li><li>Clique em Confirmar e salvar para gravar a coordenada no cliente.</li></ol><div class="guide-visual"><span class="guide-chip">🔎 Pesquisar</span><span class="guide-chip">📍 Ajustar marcador</span><span class="guide-chip green">Confirmar e salvar</span></div></section>
<section class="guide-slide"><h3>5. Cadastrar coordenadas manualmente</h3><p>Se a pesquisa não encontrar o endereço exato, preencha Latitude e Longitude manualmente.</p><ul class="guide-steps"><li>Use valores decimais, por exemplo: -5.8092100 e -35.2016200.</li><li>Usar centro atual do mapa copia o ponto central para os campos.</li><li>A opção de preencher o endereço pela coordenada vem desmarcada; marque apenas se desejar substituir o endereço de instalação pelo resultado localizado.</li><li>Abrir Google Maps ajuda a conferir o endereço em outra guia.</li></ul><div class="guide-visual"><span class="guide-chip">Latitude</span><span class="guide-chip">Longitude</span><span class="guide-chip red">Revisar antes de salvar</span></div></section>
<section class="guide-slide"><h3>6. Tráfego em tempo real</h3><p>Ao abrir um cliente online, o gráfico mostra download, upload, escala em Mbps, horário das coletas e o último ponto coletado. O módulo inclui seu próprio cliente da API RouterOS e não depende da Busca Inteligente.</p><ul class="guide-steps"><li>Passe o mouse sobre um ponto para ver horário, download e upload.</li><li>Clique em AMPLIAR para abrir o monitoramento dedicado sem a atualização geral fechar a janela.</li><li>Na tela ampliada, pesquise outro cliente online por nome ou login.</li><li>SAIR DO MONITORAMENTO volta ao mapa; no atalho Tráfego de cliente, retorna ao MK-AUTH.</li><li>Ao entrar no mapa, os ramais/NAS são verificados a cada 2 minutos; uma falha de API gera aviso identificando o equipamento.</li></ul><div class="guide-visual"><span class="guide-chip green">Cliente online</span><span class="guide-chip">📈 AMPLIAR</span><span class="guide-chip red">API NAS indisponível</span></div></section>
<section class="guide-slide"><h3>7. Empresa, NAS e caixas CTO</h3><p>Os atalhos inferiores localizam a estrutura do provedor usando as coordenadas cadastradas no MK-AUTH.</p><ul class="guide-steps"><li>EMPRESA, em azul, centraliza o endereço do provedor.</li><li>NAS, em laranja, mostra os ramais ou concentradores PPPoE com coordenadas.</li><li>Em MAPA, marque Caixas CTO para carregar a integração opcional; ela vem desmarcada.</li><li>Se o Mapa de CTO não estiver instalado, o sistema orienta entrar em contato com Bruno Fontes.</li><li>O radar estrutural dura 5 segundos e enquadra todos os pontos quando houver mais de um.</li></ul><div class="guide-visual"><span class="guide-chip blue">🏢 EMPRESA</span><span class="guide-chip orange">📡 NAS</span><span class="guide-chip">📦 CTO</span></div></section>
<section class="guide-slide"><h3>8. Alertas, notificações e sirene</h3><p>Alerta define quantos clientes precisam cair dentro da janela de detecção para gerar um ALERTA CRÍTICO. Notificações controlam os avisos individuais e Sirene controla o som.</p><ul class="guide-steps"><li>O alerta possui proteção contra oscilações e limite de balões.</li><li>A sirene de queda em massa só toca quando o limite selecionado é atingido.</li><li>O navegador exige uma interação com a página antes de permitir áudio.</li><li>Abra a barra ao lado do ? e use Executar para demonstrar sirene, queda em massa e popups sem alterar clientes reais.</li></ul><div class="guide-visual"><span class="guide-chip red">ALERTA CRÍTICO</span><span class="guide-chip">🔊 Sirene</span><span class="guide-chip green">Cliente voltou</span></div></section>
<section class="guide-slide"><h3>9. Fixar mapa e segurança</h3><p>FIXAR MAPA autoriza este dispositivo a continuar exibindo o painel mesmo se a sessão administrativa expirar.</p><ul class="guide-steps"><li>Quando ativo, o botão muda para DESTRAVAR MAPA.</li><li>Ao destravar, uma sessão MK-AUTH ainda válida continua normalmente.</li><li>Se a sessão já tiver expirado, o acesso volta para o login administrativo.</li><li>Não compartilhe o dispositivo fixado. Use VOLTAR NO MK-AUTH para retornar ao painel.</li></ul><div class="guide-visual"><span class="guide-chip green">FIXAR MAPA</span><span class="guide-chip red">DESTRAVAR MAPA</span><span class="guide-chip">VOLTAR NO MK-AUTH</span></div></section>
<section class="guide-slide"><h3>10. Tela cheia e uso no celular</h3><p>O botão de cantos no topo abre o mapa em tela cheia. A seta lateral recolhe a lista para ampliar a área útil.</p><ul class="guide-steps"><li>Alertas e notificações continuam funcionando em tela cheia.</li><li>No celular, use Clientes para abrir a coluna e o botão azul × para fechá-la.</li><li>O popup do cliente e a janela AJUSTAR LOCALIZAÇÃO ocupam a tela para facilitar leitura e toque.</li><li>Para testar a sirene no iPhone, retire o aparelho do modo silencioso e toque em Executar.</li><li>Pressione ESC para fechar janelas abertas, sair da tela cheia ou cancelar uma edição.</li></ul><div class="guide-visual"><span class="guide-chip">⛶ Tela cheia</span><span class="guide-chip">↔ Recolher lista</span><span class="guide-chip blue">Mobile responsivo</span></div></section>
</div><div class="guide-footer"><span id="guide-progress" class="guide-progress">1 de 10</span><div class="guide-nav"><button id="guide-prev" type="button">Anterior</button><button id="guide-next" class="primary" type="button">Próximo</button></div></div></div></div>
<script src="../../scripts/jquery.js"></script>
<script src="../../scripts/leaflet.js"></script>
<script src="assets/leaflet.markercluster.js"></script>
<script>
(function(){
  'use strict';
  window.addEventListener('error',function(e){var list=document.getElementById('client-list');if(list&&list.textContent.indexOf('Carregando clientes')!==-1)list.innerHTML='<div class="empty">Falha ao iniciar o mapa. Atualize com Ctrl+F5.<br><small>'+esc(e.message||'erro de JavaScript')+'</small></div>';});
  var state={clients:[],providers:[],branches:[],providerMarkers:[],branchMarkers:[],filter:'all',query:'',markers:{},previous:{},pending:{},initial:true,loading:false,editingClient:null,selectedAddress:null,adminAuthenticated:false,sidebarBeforeFullscreen:false,ctoFocusLogins:null};
  var coordinateCsrf=<?php echo json_encode($map_coord_csrf); ?>;
  var map=L.map('map',{preferCanvas:true}).setView([-15,-47],4);
  var street=L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png',{maxZoom:19,attribution:'&copy; OpenStreetMap'});
  var satellite=L.tileLayer('https://server.arcgisonline.com/ArcGIS/rest/services/World_Imagery/MapServer/tile/{z}/{y}/{x}',{maxZoom:19,attribution:'Tiles &copy; Esri'});
  street.addTo(map);
  var clusterAvailable=(typeof L.markerClusterGroup==='function');
  var cluster;
  try{cluster=clusterAvailable?L.markerClusterGroup({chunkedLoading:true,removeOutsideVisibleBounds:true,maxClusterRadius:55}):L.featureGroup();}catch(clusterError){clusterAvailable=false;cluster=L.featureGroup();}
  var plain=L.featureGroup();
  var providers=L.layerGroup().addTo(map),branches=L.layerGroup().addTo(map),ctos=L.layerGroup(),siteRadar=L.layerGroup().addTo(map),radarMarker=null,radarTimer=null,siteRadarTimer=null,ctosLoaded=false,ctosLoading=false,ctoData=[],ctoPromise=null,ctoFocusMarker=null;
  var activeLayer=clusterAvailable?cluster:plain; activeLayer.addTo(map);
  var visualizationControl=L.control.layers({'Mapa':street,'Satélite':satellite},{'Provedores':providers,'Concentradores PPPoE':branches,'Caixas CTO':ctos},{position:window.matchMedia('(max-width:760px)').matches?'bottomleft':'bottomleft',collapsed:true}).addTo(map);
  var siteNav=L.control({position:'bottomleft'});siteNav.onAdd=function(){var box=L.DomUtil.create('div','site-nav-control'),company=L.DomUtil.create('button','site-nav-button provider',box),nas=L.DomUtil.create('button','site-nav-button branch',box);company.type='button';company.textContent='EMPRESA';company.title='Localizar empresa';nas.type='button';nas.textContent='NAS';nas.title='Localizar concentradores';L.DomEvent.disableClickPropagation(box);L.DomEvent.on(company,'click',function(){focusSites('provider');});L.DomEvent.on(nas,'click',function(){focusSites('branch');});return box;};siteNav.addTo(map);
  function collapseVisualization(){setTimeout(function(){var control=visualizationControl&&visualizationControl.getContainer();if(control)control.classList.remove('leaflet-control-layers-expanded');},120);}map.on('baselayerchange overlayadd overlayremove',collapseVisualization);
  function ctoIcon(c){var label=c&&c.number?esc(c.number):'▣';return L.divIcon({className:'cto-site-icon',html:'<div class="cto-site-box">'+label+'</div>',iconSize:[40,32],iconAnchor:[20,16],popupAnchor:[0,-18]});}
  function ctoPopup(c){var groups={};(c.clients||[]).forEach(function(client){var port=String(client.port||'Sem porta');if(!groups[port])groups[port]=[];groups[port].push(client);});var ports=Object.keys(groups).sort(function(a,b){return (parseInt(a,10)||9999)-(parseInt(b,10)||9999)||a.localeCompare(b);}),html='<div class="cto-popup"><h3>📦 '+value(c.name||'Caixa CTO')+'</h3><div class="cto-summary">'+(c.type?'Tipo: '+value(c.type)+' · ':'')+(c.capacity?'Capacidade: '+value(c.capacity)+' · ':'')+'Clientes: '+(c.clients||[]).length+(c.address?'<br>'+value(c.address):'')+'</div><div class="cto-port-list">';if(!ports.length)html+='<div class="client-cto-empty">Nenhum cliente vinculado a esta CTO.</div>';ports.forEach(function(port){html+='<div class="cto-port"><strong>Porta '+value(port)+'</strong>';groups[port].forEach(function(client){var current=state.clients.find(function(item){return item.login===client.login;}),status=current?current.status:'';html+='<div class="cto-client"><i class="cto-client-dot '+status+'"></i><span>'+value(client.name||client.login)+' <small>('+value(client.login)+')</small></span></div>';});html+='</div>';});return html+'</div></div>';}
  function ensureCtos(){if(ctoPromise)return ctoPromise;ctosLoading=true;ctoPromise=fetch('cto_api.hhvm',{credentials:'same-origin',cache:'no-store'}).then(function(r){return r.json();}).then(function(data){if(!data.ok)throw new Error(data.error||'Falha ao consultar CTOs.');if(!data.installed){map.removeLayer(ctos);toast('MAPA DE CTO não está instalado. Entre em contato com Bruno Fontes.','down');return [];}ctoData=data.ctos||[];return ctoData;}).catch(function(e){ctoPromise=null;map.removeLayer(ctos);toast('Não foi possível carregar as CTOs: '+e.message,'down');return [];}).finally(function(){ctosLoading=false;});return ctoPromise;}
  function restoreCtoFocus(){if(!state.ctoFocusLogins)return;state.ctoFocusLogins=null;ctoFocusMarker=null;render();}
  function focusCto(c,marker){var logins={};(c.clients||[]).forEach(function(client){logins[client.login]=true;});state.ctoFocusLogins=logins;ctoFocusMarker=marker;activePopupLogin=null;rebuildMarkers();var points=[[c.lat,c.lon]];(c.clients||[]).forEach(function(client){if(client.lat!=null&&client.lon!=null)points.push([client.lat,client.lon]);});if(points.length>1)map.fitBounds(points,{padding:[55,55],maxZoom:18});else map.setView([c.lat,c.lon],18);}
  function loadCtos(){if(ctosLoaded||ctosLoading)return;ensureCtos().then(function(items){ctos.clearLayers();items.forEach(function(c){var marker=L.marker([c.lat,c.lon],{icon:ctoIcon(c),title:c.name||'Caixa CTO'}).bindPopup(ctoPopup(c),{maxWidth:390});marker.on('popupopen',function(){focusCto(c,marker);});marker.on('popupclose',function(){if(ctoFocusMarker===marker)restoreCtoFocus();});marker.addTo(ctos);});ctosLoaded=true;if(!items.length)toast('O MAPA DE CTO está instalado, mas não há caixas com coordenadas.','down');});}
  map.on('overlayadd',function(e){if(e.layer===ctos)loadCtos();});
  var savedBaseLayer=localStorage.getItem('mapsBaseLayer');
  map.on('baselayerchange',function(e){var selected=e.layer===satellite?'satellite':'map';localStorage.setItem('mapsBaseLayer',selected);savedBaseLayer=selected;});
  function esc(v){return String(v==null?'':v).replace(/[&<>"']/g,function(c){return {'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[c];});}
  function value(v){return v==null||v===''?'—':esc(v);}
  function duration(sec){if(sec==null)return '—';sec=Math.max(0,Number(sec)||0);var d=Math.floor(sec/86400),h=Math.floor(sec%86400/3600),m=Math.floor(sec%3600/60);return (d?d+'d ':'')+(h?h+'h ':'')+m+'min';}
  function dateText(v){if(!v)return '—';var d=new Date(String(v).replace(' ','T'));return isNaN(d.getTime())?value(v):d.toLocaleString('pt-BR');}
  function distance(a,b){var R=6371,p=Math.PI/180,dLat=(b.lat-a.lat)*p,dLon=(b.lon-a.lon)*p,s1=Math.sin(dLat/2),s2=Math.sin(dLon/2),x=s1*s1+Math.cos(a.lat*p)*Math.cos(b.lat*p)*s2*s2;return 2*R*Math.atan2(Math.sqrt(x),Math.sqrt(1-x));}
  function nearestProvider(c){if(!c.has_coordinates||!state.providers.length)return null;var best=null;state.providers.forEach(function(p){var km=distance(c,p);if(!best||km<best.km)best={name:p.name,km:km};});return best;}
  function popup(c){var p=nearestProvider(c),rows=[['Login',c.login],['Status',c.status==='online'?'Online':'Offline'],['Contrato',c.blocked?'🔒 Bloqueado':'Ativo'],['Tempo online',c.status==='online'?duration(c.online_seconds):null],['Conectado em',c.connected_at],['Última desconexão',c.last_disconnected_at],['IP atual',c.framed_ip],['MAC sessão',c.calling_station_id],['NAS',c.nas_ip],['Porta NAS',c.nas_port],['Sessões abertas',c.session_count||null],['Plano',c.plan],['Interface',c.interface],['Ramal',c.branch],['Porta OLT',c.olt_port],['CTO',c.cto],['Porta CTO',c.splitter_port],['ONU/ONT',c.onu_ont],['Distância',p?(p.km<1?Math.round(p.km*1000)+' m':p.km.toFixed(2)+' km')+' de '+p.name:null]];
    var html='<div class="popup"><h3>'+value(c.name||c.login)+'</h3><div class="popup-grid">';rows.forEach(function(r){if(r[1]!=null&&r[1]!==''){var shown=(r[0].indexOf(' em')>0||r[0].indexOf('desconexão')>0?dateText(r[1]):value(r[1]));if(r[0]==='Última desconexão')shown+=' <a class="client-log-btn" href="../../relatorios_u.hhvm?login='+encodeURIComponent(c.login)+'" target="_blank" rel="noopener">LOG</a>';html+='<b>'+esc(r[0])+'</b><span class="'+(r[0]==='Status'?'status-'+c.status:(r[0]==='Contrato'&&c.blocked?'status-offline':''))+'">'+shown+'</span>';}});html+='</div><button class="coordinate-edit-btn" type="button" data-coordinate-login="'+esc(c.login)+'">📍 AJUSTAR LOCALIZAÇÃO</button>';if(c.status==='online')html+='<div class="traffic-mini" data-traffic-login="'+esc(c.login)+'"><div class="traffic-mini-title"><span>Tráfego em tempo real</span><span class="traffic-mini-status">Conectando…</span></div><svg class="traffic-mini-chart" viewBox="0 0 400 92" preserveAspectRatio="none"><line class="traffic-mini-grid" x1="34" y1="8" x2="400" y2="8"/><line class="traffic-mini-grid" x1="34" y1="46" x2="400" y2="46"/><line class="traffic-mini-grid" x1="34" y1="84" x2="400" y2="84"/><text class="traffic-mini-scale traffic-scale-max" x="2" y="11">1 Mbps</text><text class="traffic-mini-scale traffic-scale-mid" x="2" y="49">0.5</text><text class="traffic-mini-scale" x="20" y="87">0</text><polyline class="traffic-mini-rx" points=""></polyline><polyline class="traffic-mini-tx" points=""></polyline></svg><div class="traffic-mini-legend">↓ Download <b class="traffic-rx">0</b> Mbps &nbsp; ↑ Upload <b class="traffic-tx">0</b> Mbps</div></div>';else html+='<div class="traffic-unavailable">Tráfego em tempo real disponível quando o cliente estiver online.</div>';return html+'</div>';
  }
  function icon(status,blocked){return L.divIcon({html:'<div class="pin '+status+(blocked?' locked':'')+'"></div>',className:'',iconSize:[22,22],iconAnchor:[11,11]});}
  var trafficTimer=null,trafficRequest=null,trafficLogin=null,activePopupLogin=null,rebuildingMarkers=false,monitorMode=false,monitorPopupElement=null,trafficSeries={rx:[],tx:[],times:[]};
  function stopTraffic(reset){if(trafficTimer){clearTimeout(trafficTimer);trafficTimer=null;}if(trafficRequest){trafficRequest.abort();trafficRequest=null;}if(reset!==false)trafficSeries={rx:[],tx:[],times:[]};}
  function trafficPoints(values,max){return values.map(function(v,i){var x=values.length<2?400:(34+i*366/(values.length-1)),y=84-(Number(v||0)/max*76);return x.toFixed(1)+','+y.toFixed(1);}).join(' ');}
  function trafficScale(v){if(v>=100)return Math.ceil(v).toFixed(0);if(v>=10)return (Math.ceil(v*2)/2).toFixed(1);return (Math.ceil(v*10)/10).toFixed(1);}
  function trafficDots(box,values,max,kind){var svg=box.querySelector('.traffic-mini-chart'),group=svg.querySelector('.traffic-mini-dots-'+kind);if(!group){group=document.createElementNS('http://www.w3.org/2000/svg','g');group.setAttribute('class','traffic-mini-dots-'+kind);svg.appendChild(group);}while(group.firstChild)group.removeChild(group.firstChild);var n=Math.max(values.length-1,1);values.forEach(function(v,i){var dot=document.createElementNS('http://www.w3.org/2000/svg','circle'),tip=document.createElementNS('http://www.w3.org/2000/svg','title');dot.setAttribute('cx',34+(366*i/n));dot.setAttribute('cy',84-(Math.min(v,max)/max*76));dot.setAttribute('r',i===values.length-1?'3.2':'2');dot.setAttribute('class','traffic-mini-dot-'+kind+(i===values.length-1?' traffic-mini-dot-last':''));tip.textContent='Coleta '+trafficSeries.times[i]+' · Download '+trafficSeries.rx[i].toFixed(2)+' Mbps · Upload '+trafficSeries.tx[i].toFixed(2)+' Mbps';dot.appendChild(tip);group.appendChild(dot);});}
  function renderTraffic(box,data){trafficSeries.rx.push(Number(data.rx_mbps)||0);trafficSeries.tx.push(Number(data.tx_mbps)||0);trafficSeries.times.push(new Date().toLocaleTimeString('pt-BR'));if(trafficSeries.rx.length>24){trafficSeries.rx.shift();trafficSeries.tx.shift();trafficSeries.times.shift();}var observed=Math.max.apply(null,trafficSeries.rx.concat(trafficSeries.tx)),max=Math.max(1,Number(trafficScale(observed)));box.querySelector('.traffic-mini-rx').setAttribute('points',trafficPoints(trafficSeries.rx,max));box.querySelector('.traffic-mini-tx').setAttribute('points',trafficPoints(trafficSeries.tx,max));trafficDots(box,trafficSeries.rx,max,'rx');trafficDots(box,trafficSeries.tx,max,'tx');box.querySelector('.traffic-scale-max').textContent=trafficScale(max)+' Mbps';box.querySelector('.traffic-scale-mid').textContent=trafficScale(max/2);box.querySelector('.traffic-rx').textContent=(Number(data.rx_mbps)||0).toFixed(2);box.querySelector('.traffic-tx').textContent=(Number(data.tx_mbps)||0).toFixed(2);box.querySelector('.traffic-mini-status').textContent=(data.ping_ms!=null?data.ping_ms+' ms · ':'')+(data.uptime||'online');}
  function setMonitorMode(on){monitorMode=!!on;if(monitorMode){monitorPopupElement=document.querySelector('#map .leaflet-popup');if(monitorPopupElement)document.body.appendChild(monitorPopupElement);document.body.classList.add('monitor-client');setTimeout(setupMonitorSearch,0);}else{if(document.body.classList.contains('monitor-entry')){location.href='/admin/';return;}document.querySelectorAll('.monitor-client-search').forEach(function(search){search.remove();});document.body.classList.remove('monitor-client');if(monitorPopupElement&&monitorPopupElement.isConnected){var pane=document.querySelector('#map .leaflet-popup-pane');if(pane)pane.appendChild(monitorPopupElement);}monitorPopupElement=null;}var btn=document.querySelector('.traffic-monitor-btn');if(btn)btn.textContent=monitorMode?'SAIR DO MONITORAMENTO':'AMPLIAR';if(monitorMode){if(refreshTimer)clearTimeout(refreshTimer);if(countdownTimer)clearInterval(countdownTimer);document.getElementById('countdown').textContent='Monitoramento dedicado';setTimeout(function(){map.invalidateSize();},100);}else scheduleRefresh();}
  function switchMonitoredClient(c){var content=document.querySelector('.monitor-client .leaflet-popup-content');if(!content||!c)return;stopTraffic();trafficLogin=null;activePopupLogin=c.login;content.innerHTML=popup(c);setupMonitorButton();setupMonitorSearch();startTraffic(c.login);}
  function setupMonitorSearch(){if(!monitorMode)return;var traffic=document.querySelector('.monitor-client .traffic-mini');if(!traffic||traffic.querySelector('.monitor-client-search'))return;var wrap=document.createElement('div'),input=document.createElement('input'),results=document.createElement('div');wrap.className='monitor-client-search';input.type='search';input.placeholder='Buscar outro cliente online por nome ou login';input.setAttribute('aria-label','Buscar outro cliente para monitorar');results.className='monitor-search-results';wrap.appendChild(input);wrap.appendChild(results);traffic.insertBefore(wrap,traffic.firstChild);input.addEventListener('input',function(){var q=this.value.trim().toLowerCase();results.innerHTML='';if(q.length<2)return;var found=state.clients.filter(function(c){return c.status==='online'&&((c.name||'').toLowerCase().indexOf(q)!==-1||(c.login||'').toLowerCase().indexOf(q)!==-1);}).slice(0,10);if(!found.length){results.innerHTML='<div class="monitor-search-empty">Nenhum cliente online encontrado.</div>';return;}found.forEach(function(c){var button=document.createElement('button');button.type='button';button.className='monitor-search-result';button.innerHTML='<strong>'+esc(c.name||c.login)+'</strong><small>'+esc(c.login)+' · Online</small>';button.addEventListener('click',function(){switchMonitoredClient(c);});results.appendChild(button);});});input.addEventListener('keydown',function(e){if(e.key==='Escape'){results.innerHTML='';this.value='';e.stopPropagation();}});}
  function setupMonitorButton(){var title=document.querySelector('.traffic-mini-title'),chart=document.querySelector('.traffic-mini-chart');if(chart)chart.setAttribute('preserveAspectRatio','xMidYMid meet');if(!title||title.querySelector('.traffic-monitor-btn'))return;var btn=document.createElement('button');btn.type='button';btn.className='traffic-monitor-btn';btn.textContent=monitorMode?'SAIR DO MONITORAMENTO':'AMPLIAR';btn.addEventListener('click',function(e){e.preventDefault();e.stopPropagation();setMonitorMode(!monitorMode);});title.appendChild(btn);}
  function pollTraffic(login){var box=document.querySelector('.traffic-mini[data-traffic-login="'+CSS.escape(login)+'"]');if(!box)return stopTraffic();trafficRequest=new AbortController();fetch('traffic_api.hhvm?login='+encodeURIComponent(login),{credentials:'same-origin',cache:'no-store',signal:trafficRequest.signal}).then(function(r){return r.json().then(function(data){if(!r.ok||!data.ok)throw new Error(data.error||'HTTP '+r.status);return data;});}).then(function(data){renderTraffic(box,data);}).catch(function(e){if(e.name!=='AbortError'){var status=box.querySelector('.traffic-mini-status');if(status)status.textContent=e.message;}}).finally(function(){trafficRequest=null;if(document.querySelector('.traffic-mini[data-traffic-login="'+CSS.escape(login)+'"]'))trafficTimer=setTimeout(function(){pollTraffic(login);},3000);});}
  function startTraffic(login){stopTraffic(trafficLogin!==login);trafficLogin=login;setTimeout(function(){pollTraffic(login);},80);}
  function setupClientCtoRoute(c){if(!c||!c.cto||!c.has_coordinates)return;var popupBox=document.querySelector('#map .leaflet-popup .popup');if(!popupBox||popupBox.querySelector('.client-cto-route'))return;var section=document.createElement('div');section.className='client-cto-route';section.innerHTML='<div class="client-cto-route-title"><span>Cliente → CTO</span><span>'+value(c.cto)+(c.splitter_port?' · Porta '+value(c.splitter_port):'')+'</span></div><div class="client-cto-map"><div class="client-cto-empty">Localizando CTO…</div></div>';var coordinateButton=popupBox.querySelector('.coordinate-edit-btn'),traffic=popupBox.querySelector('.traffic-mini,.traffic-unavailable');if(coordinateButton&&coordinateButton.nextSibling)popupBox.insertBefore(section,coordinateButton.nextSibling);else if(traffic)popupBox.insertBefore(section,traffic);else popupBox.appendChild(section);ensureCtos().then(function(items){if(!section.isConnected)return;var wanted=String(c.cto||'').trim().toLowerCase(),cto=items.find(function(item){return String(item.name||'').trim().toLowerCase()===wanted||String(item.id)===wanted;});var holder=section.querySelector('.client-cto-map');if(!cto){holder.innerHTML='<div class="client-cto-empty">CTO vinculada não localizada no Mapa de CTO.</div>';return;}holder.innerHTML='';var mini=L.map(holder,{zoomControl:false,attributionControl:false,dragging:false,scrollWheelZoom:false,doubleClickZoom:false,boxZoom:false,keyboard:false,tap:false});L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png',{maxZoom:19}).addTo(mini);var clientPoint=[c.lat,c.lon],ctoPoint=[cto.lat,cto.lon];L.circleMarker(clientPoint,{radius:7,color:'#fff',weight:2,fillColor:c.status==='online'?'#159447':'#d13c3c',fillOpacity:1}).bindTooltip('Cliente').addTo(mini);L.marker(ctoPoint,{icon:ctoIcon(cto)}).bindTooltip(cto.name||'CTO').addTo(mini);L.polyline([clientPoint,ctoPoint],{color:'#1769aa',weight:4,dashArray:'8 7',opacity:.9}).addTo(mini);mini.fitBounds([clientPoint,ctoPoint],{padding:[24,24],maxZoom:18});setTimeout(function(){mini.invalidateSize();},100);});}
  function rebuildMarkers(){var reopen=activePopupLogin;rebuildingMarkers=true;stopTraffic(false);cluster.clearLayers();plain.clearLayers();state.markers={};filtered().forEach(function(c){if(!c.has_coordinates)return;var m=L.marker([c.lat,c.lon],{icon:icon(c.status,c.blocked),title:(c.name||c.login)+(c.blocked?' — bloqueado':'')}).bindPopup(popup(c),{maxWidth:460});m.on('popupopen',function(){activePopupLogin=c.login;setTimeout(function(){setupClientCtoRoute(c);},0);if(c.status==='online'){startTraffic(c.login);setTimeout(setupMonitorButton,0);}});m.on('popupclose',function(){if(!rebuildingMarkers&&state.markers[c.login]===m){setMonitorMode(false);activePopupLogin=null;trafficLogin=null;stopTraffic();}});state.markers[c.login]=m;cluster.addLayer(m);plain.addLayer(m);});rebuildingMarkers=false;if(reopen&&state.markers[reopen])setTimeout(function(){state.markers[reopen].openPopup();},0);}
  function filtered(){var q=state.query.toLowerCase();return state.clients.filter(function(c){if(state.ctoFocusLogins&&!state.ctoFocusLogins[c.login])return false;if(state.filter==='online'&&c.status!=='online')return false;if(state.filter==='offline'&&c.status!=='offline')return false;if(state.filter==='unmapped'&&c.has_coordinates)return false;if(!q)return true;return [c.name,c.login,c.framed_ip,c.calling_station_id,c.registered_ip,c.registered_mac].some(function(v){return v&&String(v).toLowerCase().indexOf(q)!==-1;});});}
  function renderList(){var list=document.getElementById('client-list'),items=filtered();if(!items.length){list.innerHTML='<div class="empty">Nenhum cliente encontrado.</div>';return;}list.innerHTML=items.map(function(c){var when=c.status==='online'?'Online há '+duration(c.online_seconds):(c.last_disconnected_at?'Desconectou '+dateText(c.last_disconnected_at):'Sem histórico de desconexão');return '<div class="client" data-login="'+esc(c.login)+'"><div class="client-name"><span class="dot '+c.status+'"></span> '+value(c.name||c.login)+'</div><div class="client-meta"><span>'+value(c.login)+'</span><span>'+esc(when)+'</span>'+(!c.has_coordinates?'<span class="badge">sem coordenadas</span>':'')+'</div></div>';}).join('');}
  function render(){rebuildMarkers();renderList();}
  function counts(s){document.getElementById('count-total').textContent=s.total;document.getElementById('count-online').textContent=s.online;document.getElementById('count-offline').textContent=s.offline;document.getElementById('count-unmapped').textContent=s.unmapped;}
  function toast(text,type){var box=document.getElementById('toast-container'),el=document.createElement('div');el.className='toast '+type;el.textContent=text;box.insertBefore(el,box.firstChild);while(box.children.length>3)box.removeChild(box.lastChild);setTimeout(function(){if(el.parentNode)el.parentNode.removeChild(el);},6500);}
  var nasHealthSignature=null,nasHealthTimer=null;
  function checkNasHealth(){fetch('nas_health.hhvm',{credentials:'same-origin',cache:'no-store'}).then(function(r){return r.json();}).then(function(data){if(!data.ok)throw new Error(data.error||'Falha na verificação das APIs.');var bad=data.offline||[],signature=bad.map(function(n){return n.ip+'|'+n.message;}).sort().join(';');if(bad.length&&signature!==nasHealthSignature){var names=bad.slice(0,5).map(function(n){return n.name+' ('+n.ip+')';}).join(', ');toast('API MikroTik indisponível: '+names+'. O tráfego em tempo real pode ficar indisponível.','down');}else if(!bad.length&&nasHealthSignature)toast('Todas as APIs MikroTik dos ramais/NAS estão conectadas.','up');nasHealthSignature=signature;}).catch(function(e){if(nasHealthSignature===null)toast('Não foi possível verificar as APIs MikroTik: '+e.message,'down');nasHealthSignature='health-error';});}
  var audioContext=null,sirenTimer=null,sirenOscillator=null;
  function prepareAudio(){if(!audioContext){var AudioCtor=window.AudioContext||window.webkitAudioContext;if(AudioCtor)audioContext=new AudioCtor();}if(audioContext&&audioContext.state==='suspended')audioContext.resume();}
  function stopSiren(){if(sirenTimer){clearInterval(sirenTimer);sirenTimer=null;}if(sirenOscillator){try{sirenOscillator.stop();}catch(e){}sirenOscillator=null;}}
  function startSiren(force){if(!force&&!document.getElementById('alert-sound').checked)return;prepareAudio();if(!audioContext)return;var begin=function(){stopSiren();var gain=audioContext.createGain();gain.gain.setValueAtTime(.0001,audioContext.currentTime);gain.gain.exponentialRampToValueAtTime(.22,audioContext.currentTime+.04);gain.connect(audioContext.destination);sirenOscillator=audioContext.createOscillator();sirenOscillator.type='sawtooth';sirenOscillator.frequency.setValueAtTime(620,audioContext.currentTime);sirenOscillator.connect(gain);sirenOscillator.start(audioContext.currentTime);var high=false;sirenTimer=setInterval(function(){high=!high;if(sirenOscillator)sirenOscillator.frequency.setValueAtTime(high?980:620,audioContext.currentTime);},420);};var resumed=audioContext.resume();if(resumed&&resumed.then)resumed.then(begin).catch(function(){toast('O celular bloqueou o áudio. Retire o modo silencioso e toque novamente em Executar.','down');});else begin();}
  function criticalAlert(total,forceSound){document.getElementById('critical-count').textContent=total;document.getElementById('critical-alert').classList.add('show');if(forceSound===true)startSiren(true);else if(forceSound!==false)startSiren(false);}
  function closeCritical(){document.getElementById('critical-alert').classList.remove('show');stopSiren();}
  function changes(clients){if(state.initial)return;var confirmed=[];clients.forEach(function(c){var old=state.previous[c.login];if(!old){state.previous[c.login]=c.status;return;}if(old===c.status){delete state.pending[c.login];return;}var p=state.pending[c.login];if(!p||p.status!==c.status){state.pending[c.login]={status:c.status,count:1};return;}p.count++;if(p.count>=2){confirmed.push(c);state.previous[c.login]=c.status;delete state.pending[c.login];}});if(!document.getElementById('notifications').checked||!confirmed.length)return;var up=confirmed.filter(function(c){return c.status==='online';}),down=confirmed.filter(function(c){return c.status==='offline';}),threshold=Number(document.getElementById('mass-threshold').value);if(up.length)toast(up.length===1?(up[0].name||up[0].login)+' voltou online':up.length+' clientes voltaram online','up');if(threshold>0&&down.length>=threshold)criticalAlert(down.length);else if(down.length)toast(down.length===1?(down[0].name||down[0].login)+' ficou offline':down.length+' clientes ficaram offline','down');}
  var refreshTimer=null,countdownTimer=null,nextRefreshAt=0,monitorShortcutOpened=false;
  function openMonitorShortcut(){if(monitorShortcutOpened||new URLSearchParams(location.search).get('monitor')!=='1')return;var c=state.clients.find(function(client){return client.status==='online'&&client.has_coordinates&&state.markers[client.login];});if(!c)return;var marker=state.markers[c.login],attempts=0,launch=function(){attempts++;marker.openPopup();setTimeout(function(){if(document.querySelector('#map .leaflet-popup')){monitorShortcutOpened=true;setMonitorMode(true);}else if(attempts<5){map.setView([c.lat,c.lon],18);setTimeout(launch,180);}else toast('Não foi possível abrir o monitoramento automaticamente. Selecione um cliente no mapa.','down');},100);};if(map.hasLayer(cluster)&&cluster.zoomToShowLayer)cluster.zoomToShowLayer(marker,launch);else{map.setView([c.lat,c.lon],18);setTimeout(launch,180);}}
  function refreshSeconds(){return Number(document.getElementById('refresh-interval').value)||60;}
  function updateCountdown(){var remaining=Math.max(0,Math.ceil((nextRefreshAt-Date.now())/1000));document.getElementById('countdown').textContent='Próxima atualização: '+remaining+'s';}
  function scheduleRefresh(){if(refreshTimer)clearTimeout(refreshTimer);if(countdownTimer)clearInterval(countdownTimer);if(monitorMode){document.getElementById('countdown').textContent='Monitoramento dedicado';return;}nextRefreshAt=Date.now()+refreshSeconds()*1000;updateCountdown();countdownTimer=setInterval(updateCountdown,1000);refreshTimer=setTimeout(function(){if(countdownTimer)clearInterval(countdownTimer);document.getElementById('countdown').textContent='Atualizando…';load(false);},refreshSeconds()*1000);}
  function siteIcon(type){var symbol=type==='provider'?'🏢':'📡';return L.divIcon({className:'map-site-icon',html:'<div class="map-site-pin '+type+'">'+symbol+'</div>',iconSize:[40,40],iconAnchor:[20,20],popupAnchor:[0,-21]});}
  function addressText(item){return [item.address,item.number,item.district,item.city,item.state].filter(Boolean).join(', ');}
  function renderSites(){providers.clearLayers();branches.clearLayers();state.providerMarkers=[];state.branchMarkers=[];state.providers.forEach(function(p){var address=addressText(p),html='<b>🏢 '+value(p.name||'Provedor')+'</b>'+(address?'<br>'+value(address):''),marker=L.marker([p.lat,p.lon],{icon:siteIcon('provider'),title:p.name||'Provedor'}).bindPopup(html).addTo(providers);state.providerMarkers.push(marker);});state.branches.forEach(function(b){var address=addressText(b),html='<b>📡 '+value(b.name||b.description||'Concentrador PPPoE')+'</b>'+(b.nas?'<br>NAS: '+value(b.nas):'')+(address?'<br>'+value(address):''),marker=L.marker([b.lat,b.lon],{icon:siteIcon('branch'),title:b.name||'Concentrador PPPoE'}).bindPopup(html).addTo(branches);state.branchMarkers.push(marker);});}
  function pulseSites(items,color){siteRadar.clearLayers();if(siteRadarTimer)clearTimeout(siteRadarTimer);items.forEach(function(item){L.marker([item.lat,item.lon],{interactive:false,zIndexOffset:1300,icon:L.divIcon({className:'site-radar',html:'<span class="site-radar-ring" style="--site-radar-color:'+color+'"></span>',iconSize:[180,180],iconAnchor:[90,90]})}).addTo(siteRadar);});siteRadarTimer=setTimeout(function(){siteRadar.clearLayers();},5100);}
  function focusSites(type){var isProvider=type==='provider',items=isProvider?state.providers:state.branches,layer=isProvider?providers:branches,markers=isProvider?state.providerMarkers:state.branchMarkers;if(!items.length){toast(isProvider?'Empresa sem coordenadas cadastradas.':'Nenhum NAS com coordenadas cadastrado.','down');return;}if(!map.hasLayer(layer))layer.addTo(map);var bounds=L.latLngBounds(items.map(function(item){return [item.lat,item.lon];}));if(items.length===1){map.setView([items[0].lat,items[0].lon],17);if(markers[0])markers[0].openPopup();}else map.fitBounds(bounds.pad(.18),{maxZoom:15});pulseSites(items,isProvider?'#1769aa':'#d57918');}
  function pulseClient(c){if(!c||!c.has_coordinates)return;if(radarMarker)map.removeLayer(radarMarker);if(radarTimer)clearTimeout(radarTimer);radarMarker=L.marker([c.lat,c.lon],{interactive:false,zIndexOffset:1200,icon:L.divIcon({className:'client-radar',html:'<span class="client-radar-ring"></span>',iconSize:[100,100],iconAnchor:[50,50]})}).addTo(map);radarTimer=setTimeout(function(){if(radarMarker)map.removeLayer(radarMarker);radarMarker=null;},2050);}
  function load(manual){if(state.loading)return;if(document.hidden&&!manual){scheduleRefresh();return;}state.loading=true;fetch('maps_clientes_api.hhvm',{credentials:'same-origin',cache:'no-store'}).then(function(r){if(!r.ok)throw new Error('HTTP '+r.status);return r.json();}).then(function(data){if(!data.ok)throw new Error(data.error||'Resposta inválida');changes(data.clients);state.clients=data.clients;state.providers=data.providers||[];state.branches=data.branches||[];if(state.initial){state.previous={};state.clients.forEach(function(c){state.previous[c.login]=c.status;});}counts(data.summary);renderSites();if(state.initial){var preferred=savedBaseLayer||(data.options&&data.options.initial_layer==='satelite'?'satellite':'map');if(preferred==='satellite'){map.removeLayer(street);satellite.addTo(map);}else{map.removeLayer(satellite);street.addTo(map);}}render();document.getElementById('updated').textContent='Atualizado '+new Date().toLocaleTimeString('pt-BR');if(state.initial)fit();state.initial=false;openMonitorShortcut();}).catch(function(e){document.getElementById('client-list').innerHTML='<div class="empty">Falha ao carregar clientes.<br><small>'+esc(e.message)+'</small></div>';toast('Falha ao atualizar: '+e.message,'down');}).finally(function(){state.loading=false;scheduleRefresh();});}
  function fit(){var group=activeLayer.getLayers();if(group.length){var bounds=activeLayer.getBounds();if(bounds.isValid())map.fitBounds(bounds.pad(.08),{maxZoom:16});}}
  document.querySelectorAll('.counter').forEach(function(b){b.addEventListener('click',function(){document.querySelectorAll('.counter').forEach(function(x){x.classList.remove('active');});b.classList.add('active');state.filter=b.dataset.filter;render();});});
  document.getElementById('search').addEventListener('input',function(e){state.query=e.target.value.trim();render();});
  document.getElementById('refresh').addEventListener('click',function(){load(true);});document.getElementById('fit').addEventListener('click',fit);
  if(!clusterAvailable){document.getElementById('clusters').checked=false;document.getElementById('clusters').disabled=true;}
  document.getElementById('clusters').addEventListener('change',function(e){map.removeLayer(activeLayer);activeLayer=(clusterAvailable&&e.target.checked)?cluster:plain;activeLayer.addTo(map);});
  var savedNotifications=localStorage.getItem('mapsNotifications');document.getElementById('notifications').checked=savedNotifications===null?true:savedNotifications==='1';document.getElementById('notifications').addEventListener('change',function(e){localStorage.setItem('mapsNotifications',e.target.checked?'1':'0');});
  document.getElementById('persistent-access').addEventListener('change',function(){var checkbox=this,button=document.getElementById('persistent-access-button'),label=button.querySelector('span'),enabled=checkbox.checked;checkbox.disabled=true;button.classList.add('busy');fetch('persistent_access.hhvm',{method:'POST',credentials:'same-origin',headers:{'Content-Type':'application/x-www-form-urlencoded;charset=UTF-8'},body:'csrf='+encodeURIComponent(coordinateCsrf)+'&enabled='+(enabled?'1':'0')}).then(function(r){return r.json().then(function(data){if(!r.ok)throw new Error(data.error||'HTTP '+r.status);return data;});}).then(function(data){if(data.csrf)coordinateCsrf=data.csrf;button.classList.toggle('active',enabled);label.textContent=enabled?'DESTRAVAR MAPA':'FIXAR MAPA';toast(enabled?'Acesso permanente ativado neste dispositivo.':'Acesso permanente removido.','up');if(!enabled&&data.redirect)setTimeout(function(){window.location.href=data.redirect;},700);}).catch(function(e){checkbox.checked=!enabled;button.classList.toggle('active',!enabled);label.textContent=!enabled?'DESTRAVAR MAPA':'FIXAR MAPA';toast(e.message,'down');}).finally(function(){checkbox.disabled=false;button.classList.remove('busy');});});
  var savedThreshold=localStorage.getItem('mapsMassThreshold'),thresholdDefaultVersion=localStorage.getItem('mapsMassThresholdDefault'),validThreshold=['0','5','10','20','50','100','200','500'];if(thresholdDefaultVersion!=='10-v1'){savedThreshold='10';localStorage.setItem('mapsMassThreshold','10');localStorage.setItem('mapsMassThresholdDefault','10-v1');}document.getElementById('mass-threshold').value=validThreshold.indexOf(savedThreshold)!==-1?savedThreshold:'10';document.getElementById('mass-threshold').addEventListener('change',function(e){localStorage.setItem('mapsMassThreshold',e.target.value);});
  var validThemes=['dark','white'],savedTheme=localStorage.getItem('mapsTheme');if(savedTheme==='black')savedTheme='dark';if(validThemes.indexOf(savedTheme)===-1)savedTheme='dark';document.body.setAttribute('data-theme',savedTheme);document.getElementById('theme-select').value=savedTheme;document.getElementById('theme-select').addEventListener('change',function(e){document.body.setAttribute('data-theme',e.target.value);localStorage.setItem('mapsTheme',e.target.value);});
  var savedAlertSound=localStorage.getItem('mapsAlertSound');document.getElementById('alert-sound').checked=savedAlertSound===null||savedAlertSound==='1';document.getElementById('alert-sound').addEventListener('change',function(e){localStorage.setItem('mapsAlertSound',e.target.checked?'1':'0');if(e.target.checked)prepareAudio();else stopSiren();});document.getElementById('critical-close').addEventListener('click',closeCritical);
  document.getElementById('refresh-interval').value='60';document.getElementById('refresh-interval').addEventListener('change',function(){scheduleRefresh();});
  var coordinateMap=null,coordinateMarker=null,coordinateSearchTimer=null;
  function coordinatePosition(lat,lon){lat=Number(lat);lon=Number(lon);if(!isFinite(lat)||!isFinite(lon)||lat < -90||lat > 90||lon < -180||lon > 180)return;document.getElementById('coordinate-lat').value=lat.toFixed(7);document.getElementById('coordinate-lon').value=lon.toFixed(7);if(coordinateMarker)coordinateMarker.setLatLng([lat,lon]);if(coordinateMap)coordinateMap.setView([lat,lon],18);}
  function initCoordinateMap(){var center=map.getCenter();if(!coordinateMap){var pinIcon=L.divIcon({className:'coordinate-map-pin',html:'<div class="coordinate-map-pin-shape" title="Localização selecionada"></div>',iconSize:[36,42],iconAnchor:[15,38]});var coordinateStreet=L.tileLayer('https://tile.openstreetmap.org/{z}/{x}/{y}.png',{maxZoom:19,attribution:'&copy; OpenStreetMap contributors'});var coordinateSatellite=L.tileLayer('https://server.arcgisonline.com/ArcGIS/rest/services/World_Imagery/MapServer/tile/{z}/{y}/{x}',{maxZoom:19,attribution:'Tiles &copy; Esri'});coordinateMap=L.map('coordinate-map',{layers:[coordinateStreet]}).setView([center.lat,center.lng],15);L.control.layers({'Mapa':coordinateStreet,'Satélite':coordinateSatellite},null,{position:'bottomleft',collapsed:false}).addTo(coordinateMap);coordinateMarker=L.marker([center.lat,center.lng],{draggable:true,icon:pinIcon,title:'Localização selecionada'}).addTo(coordinateMap);coordinateMarker.on('dragend',function(){var p=coordinateMarker.getLatLng();coordinatePosition(p.lat,p.lng);});coordinateMap.on('click',function(e){coordinatePosition(e.latlng.lat,e.latlng.lng);});}else{coordinateMap.setView([center.lat,center.lng],15);coordinateMarker.setLatLng([center.lat,center.lng]);}setTimeout(function(){coordinateMap.invalidateSize();},80);}
  function featureLabel(p){return [p.name,p.street,p.housenumber,p.district||p.locality||p.neighbourhood,p.city||p.county,p.state,p.postcode].filter(function(v,i,a){return v&&a.indexOf(v)===i;}).join(', ');}
  function selectCoordinateFeature(feature){var coordinates=feature.geometry&&feature.geometry.coordinates,p=feature.properties||{};if(!coordinates||coordinates.length<2)return;state.selectedAddress=p;coordinatePosition(coordinates[1],coordinates[0]);document.getElementById('coordinate-error').textContent='Localização selecionada. Ajuste o marcador se necessário.';}
  function searchCoordinates(){var input=document.getElementById('coordinate-search'),q=input.value.trim(),box=document.getElementById('coordinate-suggestions');if(q.length<3){box.innerHTML='<div class="empty">Digite pelo menos 3 caracteres.</div>';return;}box.innerHTML='<div class="empty">Pesquisando no addon nativo…</div>';fetch('../geocodificacao/geocode.php?action=photon&q='+encodeURIComponent(q),{credentials:'same-origin',cache:'no-store'}).then(function(r){if(!r.ok)throw new Error('HTTP '+r.status);return r.json();}).then(function(data){var features=(data.features||[]).filter(function(f){return String((f.properties||{}).countrycode||'').toUpperCase()==='BR';});box.innerHTML='';if(!features.length){box.innerHTML='<div class="empty">Nenhum endereço encontrado.</div>';return;}features.forEach(function(feature){var button=document.createElement('button');button.type='button';button.className='coordinate-suggestion';button.textContent=featureLabel(feature.properties||{});button.addEventListener('click',function(){selectCoordinateFeature(feature);});box.appendChild(button);});}).catch(function(e){box.innerHTML='<div class="empty">Busca indisponível: '+esc(e.message)+'</div>';});}
  function registeredAddress(c){return [c.address,c.address_number,c.address_complement,c.district,c.city,c.state,c.postal_code].filter(Boolean).join(', ');}
  function openCoordinateModal(c){state.editingClient=c;state.selectedAddress=null;var address=registeredAddress(c),logged=!!c.uuid,correcting=!!c.has_coordinates,addressBox=document.querySelector('.registered-address'),addressTitle=addressBox.querySelector('strong');document.getElementById('coordinate-title').textContent=correcting?'Corrigir coordenadas':'Pesquisar e adicionar coordenadas';document.getElementById('coordinate-client').textContent=(c.name||c.login)+' — '+c.login;addressTitle.textContent=logged?(correcting?'Endereço cadastrado — ajuste a coordenada atual':'Endereço cadastrado, mas coordenada não preenchida'):'Sessão administrativa encerrada';document.getElementById('registered-address-text').textContent=logged?(address||'Endereço não informado no cadastro.'):'Entre novamente no MK-AUTH para consultar o cadastro e salvar coordenadas.';var editLink=document.getElementById('coordinate-client-edit');editLink.href=logged?'../../cliente_alt.hhvm?uuid='+encodeURIComponent(c.uuid):'../../login.php';editLink.textContent=logged?'Alterar diretamente no cadastro':'Entrar no MK-AUTH';document.getElementById('coordinate-google-maps').href=address?'https://www.google.com/maps/search/?api=1&query='+encodeURIComponent(address):'https://www.google.com/maps';document.getElementById('coordinate-lat').value=correcting?Number(c.lat).toFixed(7):'';document.getElementById('coordinate-lon').value=correcting?Number(c.lon).toFixed(7):'';document.getElementById('coordinate-search').value=address;document.getElementById('coordinate-fill-address').checked=false;document.getElementById('coordinate-suggestions').innerHTML='<div class="empty">'+(logged?(address?'O endereço cadastrado já foi colocado na pesquisa. Clique em Pesquisar.':'Digite pelo menos 3 caracteres para pesquisar.'):'Faça login no MK-AUTH e depois atualize esta página.')+'</div>';document.getElementById('coordinate-error').textContent=logged?(correcting?'A coordenada atual está carregada. Arraste o marcador, clique no mapa ou pesquise outro endereço.':'Você também pode digitar latitude e longitude manualmente.'):'É necessário estar logado para salvar alterações no cadastro.';document.getElementById('coordinate-save').disabled=!logged;document.getElementById('coordinate-modal').classList.add('show');initCoordinateMap();if(correcting)coordinatePosition(c.lat,c.lon);}
  function closeCoordinateModal(){state.editingClient=null;document.getElementById('coordinate-modal').classList.remove('show');}
  var coordinateTopCancel=document.createElement('button');coordinateTopCancel.id='coordinate-top-cancel';coordinateTopCancel.className='btn coordinate-top-cancel';coordinateTopCancel.type='button';coordinateTopCancel.textContent='Cancelar';coordinateTopCancel.setAttribute('aria-label','Cancelar e fechar');document.querySelector('.coordinate-head').appendChild(coordinateTopCancel);coordinateTopCancel.addEventListener('click',closeCoordinateModal);
  var fullscreenToggle=document.createElement('button');fullscreenToggle.id='fullscreen-toggle';fullscreenToggle.className='fullscreen-toggle';fullscreenToggle.type='button';fullscreenToggle.textContent='⛶';fullscreenToggle.setAttribute('aria-label','Alternar tela cheia');fullscreenToggle.title='Tela cheia';document.body.appendChild(fullscreenToggle);
  function fullscreenElement(){return document.fullscreenElement||document.webkitFullscreenElement;}
  function appFullscreen(){return !!fullscreenElement()||document.body.classList.contains('mobile-map-fullscreen');}
  function enterFullscreen(){var app=document.getElementById('app');state.sidebarBeforeFullscreen=app.classList.contains('sidebar-collapsed');app.classList.add('sidebar-collapsed');if(window.matchMedia('(max-width:760px)').matches){document.getElementById('sidebar').classList.remove('open');document.body.classList.remove('mobile-sidebar-open');document.body.classList.add('mobile-map-fullscreen');fullscreenToggle.title='Sair da tela cheia';setTimeout(function(){map.invalidateSize(true);},180);return;}var target=document.documentElement,request=target.requestFullscreen||target.webkitRequestFullscreen;if(request){var result=request.call(target);if(result&&result.catch)result.catch(function(){app.classList.toggle('sidebar-collapsed',state.sidebarBeforeFullscreen);});}fullscreenToggle.textContent='⛶';fullscreenToggle.title='Sair da tela cheia';setTimeout(function(){map.invalidateSize(true);},250);}
  function exitFullscreen(){if(document.body.classList.contains('mobile-map-fullscreen')){document.body.classList.remove('mobile-map-fullscreen');document.getElementById('app').classList.toggle('sidebar-collapsed',state.sidebarBeforeFullscreen);fullscreenToggle.title='Tela cheia';setTimeout(function(){map.invalidateSize(true);},180);return;}var exit=document.exitFullscreen||document.webkitExitFullscreen;if(exit)exit.call(document);}
  fullscreenToggle.addEventListener('click',function(){if(appFullscreen())exitFullscreen();else enterFullscreen();});
  document.addEventListener('fullscreenchange',function(){var active=!!fullscreenElement(),app=document.getElementById('app');fullscreenToggle.textContent='⛶';fullscreenToggle.title=active?'Sair da tela cheia':'Tela cheia';if(!active)app.classList.toggle('sidebar-collapsed',state.sidebarBeforeFullscreen);setTimeout(function(){map.invalidateSize();},250);});
  function ufFromProperties(p){if(p.statecode&&p.statecode.indexOf('-')!==-1)return p.statecode.split('-').pop().toUpperCase();var states={'Rio Grande do Norte':'RN','Goiás':'GO','São Paulo':'SP','Minas Gerais':'MG','Rio de Janeiro':'RJ','Paraná':'PR','Santa Catarina':'SC','Rio Grande do Sul':'RS','Bahia':'BA','Distrito Federal':'DF','Mato Grosso':'MT','Mato Grosso do Sul':'MS','Tocantins':'TO','Pará':'PA','Amazonas':'AM','Acre':'AC','Rondônia':'RO','Roraima':'RR','Amapá':'AP','Maranhão':'MA','Piauí':'PI','Ceará':'CE','Paraíba':'PB','Pernambuco':'PE','Alagoas':'AL','Sergipe':'SE','Espírito Santo':'ES'};return states[p.state]||'';}
  function saveCoordinates(){var c=state.editingClient;if(!c)return;var lat=document.getElementById('coordinate-lat').value.trim().replace(',','.'),lon=document.getElementById('coordinate-lon').value.trim().replace(',','.'),fill=document.getElementById('coordinate-fill-address').checked,p=state.selectedAddress||{};if(!isFinite(Number(lat))||!isFinite(Number(lon))){document.getElementById('coordinate-error').textContent='Informe latitude e longitude válidas.';return;}if(fill&&!state.selectedAddress){document.getElementById('coordinate-error').textContent='Para preencher o endereço, selecione primeiro um resultado da pesquisa.';return;}var message='Usar a coordenada '+lat+','+lon+' para '+(c.name||c.login)+'?';if(fill)message+=' O endereço de instalação também será preenchido com: '+featureLabel(p)+'.';else message+=' O endereço atual será mantido.';if(!window.confirm(message))return;document.getElementById('coordinate-error').textContent='Salvando…';var body=new URLSearchParams({csrf:coordinateCsrf,id:String(c.id),lat:lat,lon:lon,fill_address:fill?'1':'0',cep:p.postcode||'',endereco:p.street||p.name||'',numero:p.housenumber||'',bairro:p.district||p.locality||p.neighbourhood||'',cidade:p.city||p.county||'',estado:ufFromProperties(p),cidade_ibge:p.ibge||''});fetch('maps_clientes_coord_update.hhvm',{method:'POST',credentials:'same-origin',headers:{'Content-Type':'application/x-www-form-urlencoded;charset=UTF-8'},body:body.toString()}).then(function(r){return r.json().then(function(data){if(!r.ok)throw new Error(data.error||'HTTP '+r.status);return data;});}).then(function(data){closeCoordinateModal();toast((data.address_updated?'Coordenadas e endereço salvos para ':'Coordenadas salvas para ')+(c.name||c.login),'up');load(true);}).catch(function(e){document.getElementById('coordinate-error').textContent=e.message;});}
  document.getElementById('client-list').addEventListener('click',function(e){var el=e.target.closest('.client');if(!el)return;var c=state.clients.find(function(x){return x.login===el.dataset.login;});if(!c)return;if(c.has_coordinates&&state.markers[c.login]){map.setView([c.lat,c.lon],17);pulseClient(c);state.markers[c.login].openPopup();}else openCoordinateModal(c);});
  document.getElementById('map').addEventListener('click',function(e){var button=e.target.closest('.coordinate-edit-btn');if(!button)return;e.preventDefault();e.stopPropagation();var c=state.clients.find(function(client){return client.login===button.dataset.coordinateLogin;});if(c){openCoordinateModal(c);document.getElementById('coordinate-title').textContent='Ajustar localização';}});
  document.getElementById('coordinate-center').addEventListener('click',function(){var center=map.getCenter();coordinatePosition(center.lat,center.lng);});document.getElementById('coordinate-cancel').addEventListener('click',closeCoordinateModal);document.getElementById('coordinate-save').addEventListener('click',saveCoordinates);document.getElementById('coordinate-search-button').addEventListener('click',searchCoordinates);document.getElementById('coordinate-search').addEventListener('input',function(){clearTimeout(coordinateSearchTimer);coordinateSearchTimer=setTimeout(searchCoordinates,500);});document.getElementById('coordinate-search').addEventListener('keydown',function(e){if(e.key==='Enter'){e.preventDefault();searchCoordinates();}});document.getElementById('coordinate-lat').addEventListener('change',function(){coordinatePosition(this.value,document.getElementById('coordinate-lon').value);});document.getElementById('coordinate-lon').addEventListener('change',function(){coordinatePosition(document.getElementById('coordinate-lat').value,this.value);});
  var guideIndex=0,guideSlides=Array.prototype.slice.call(document.querySelectorAll('.guide-slide'));function showGuideSlide(index){guideIndex=Math.max(0,Math.min(guideSlides.length-1,index));guideSlides.forEach(function(slide,i){slide.classList.toggle('active',i===guideIndex);});document.getElementById('guide-progress').textContent=(guideIndex+1)+' de '+guideSlides.length;document.getElementById('guide-prev').disabled=guideIndex===0;document.getElementById('guide-next').textContent=guideIndex===guideSlides.length-1?'Concluir':'Próximo';}function openGuide(){document.getElementById('guide-modal').classList.add('show');showGuideSlide(0);}function closeGuide(){document.getElementById('guide-modal').classList.remove('show');}document.getElementById('guide-open').addEventListener('click',openGuide);document.getElementById('guide-close').addEventListener('click',closeGuide);document.getElementById('guide-prev').addEventListener('click',function(){showGuideSlide(guideIndex-1);});document.getElementById('guide-next').addEventListener('click',function(){if(guideIndex===guideSlides.length-1)closeGuide();else showGuideSlide(guideIndex+1);});document.getElementById('guide-modal').addEventListener('click',function(e){if(e.target===this)closeGuide();});
  document.addEventListener('keydown',function(e){if(e.key!=='Escape')return;closeGuide();closeCoordinateModal();closeCritical();map.closePopup();document.getElementById('toast-container').innerHTML='';stopSiren();});
  document.getElementById('sidebar-toggle').addEventListener('click',function(){var app=document.getElementById('app');app.classList.toggle('sidebar-collapsed');this.title=app.classList.contains('sidebar-collapsed')?'Mostrar painel de clientes':'Esconder painel de clientes';setTimeout(function(){map.invalidateSize();},230);});
  document.getElementById('demo-toggle').addEventListener('click',function(){var bar=document.getElementById('demo-bar');bar.classList.toggle('collapsed');this.title=bar.classList.contains('collapsed')?'Abrir alertas':'Recolher alertas';});
  document.getElementById('demo-run').addEventListener('click',function(){var option=document.getElementById('demo-alert').value,count=Number(document.getElementById('mass-threshold').value)||20;if(option==='siren'){startSiren(true);toast('Demonstração da sirene. Use o alerta crítico ou desmarque Sirene para parar.','down');setTimeout(stopSiren,6000);}if(option==='mass')criticalAlert(count,false);if(option==='online')toast('CLIENTE DEMONSTRAÇÃO voltou online','up');if(option==='offline')toast('CLIENTE DEMONSTRAÇÃO ficou offline','down');if(option==='both')criticalAlert(count,true);});
  document.getElementById('mobile-toggle').addEventListener('click',function(){var sidebar=document.getElementById('sidebar'),open=!sidebar.classList.contains('open');sidebar.classList.toggle('open',open);document.body.classList.toggle('mobile-sidebar-open',open);this.textContent=open?'×':'Clientes';this.setAttribute('aria-label',open?'Fechar clientes':'Abrir clientes');setTimeout(function(){map.invalidateSize(true);},230);});
  load(true);checkNasHealth();nasHealthTimer=setInterval(checkNasHealth,120000);
})();
</script>
</body>
</html>
