<?php
require __DIR__ . '/auth.php';
require_map_access(false);
$map_coord_csrf = map_access_csrf();
$map_persistent_access = map_access_via_trusted_device();
require __DIR__ . '/config.hhvm';
?>
<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width,initial-scale=1">
